# ─── Server ─────────────────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=8080
APP_NAME=smartbed

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smartbed
DB_USER=smartbed
DB_PASSWORD=smartbed_secret
DB_SSL_MODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME_MINUTES=5

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── MQTT ────────────────────────────────────────────────────────────────────
MQTT_BROKER=tcp://localhost:1883
MQTT_CLIENT_ID=smartbed-server
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_QOS=1
MQTT_ACK_TIMEOUT_SECONDS=30

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: openssl genrsa -out private.pem 2048
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

# ─── Migrations ──────────────────────────────────────────────────────────────
MIGRATIONS_PATH=file://migrations

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=debug   # debug | info | warn | error
LOG_PRETTY=true   # false in production (JSON)

# ─── Seeds ───────────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@smartbed.local
SEED_ADMIN_PASSWORD=Admin@2024!
